using System.Collections.Generic;
using g3;

/// <summary>
///  DMesh3 subclass that supports texture coordinates (UVs).
/// </summary>

namespace UnBox3D.Models
{
    public class DMesh3WithTextures : DMesh3
    {
        public DMesh3 Mesh;
        public Vector2f[] UVsArray;
        public Vector3f[] NormalsArray;
        public DMesh3WithTextures()
            : base()
        {
            UVs = new List<Vector2d>();
        }
        private List<g3.Vector2d> uvs = new();

        public void AppendVertexWithUV(g3.Vector3d v, g3.Vector2d uv)
        {
            int idx = AppendVertex(v); // from DMesh3
            if (idx != uvs.Count) uvs.Add(uv); // make sure list matches vertex count
        }

        public void SetUV(int vertexIndex, g3.Vector2d uv)
        {
            if (vertexIndex >= 0 && vertexIndex < uvs.Count)
                uvs[vertexIndex] = uv;
            else
                uvs.Add(uv);
        }

        public g3.Vector2d GetUV(int vertexIndex) => uvs[vertexIndex];
    }
}
