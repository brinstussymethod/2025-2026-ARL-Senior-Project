<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Light palette -->
  <ResourceDictionary x:Key="Theme.Light">
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="CardBrush"           Color="#FFF6F6F6"/>
    <SolidColorBrush x:Key="CardHoverBrush"      Color="#FFEEEEEE"/>
    <SolidColorBrush x:Key="CardPressedBrush"    Color="#FFE4E4E4"/>
    <SolidColorBrush x:Key="BorderBrushLight"    Color="#FFE0E0E0"/>
    <SolidColorBrush x:Key="BorderBrushHover"    Color="#FFBFBFBF"/>
    <SolidColorBrush x:Key="TextBrush"           Color="#FF141414"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="#FF6B6B6B"/>
    <SolidColorBrush x:Key="AccentLightBrush"    Color="#FF8C8C8C"/>
    <SolidColorBrush x:Key="NavBrush"            Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="HighlightBrush"      Color="#FF0D9488"/>
    <SolidColorBrush x:Key="HighlightLightBrush" Color="#FF14B8A6"/>
    <SolidColorBrush x:Key="DangerBrush"         Color="#FFDC2626"/>
    <SolidColorBrush x:Key="DangerHoverBrush"    Color="#FFEF4444"/>
    <SolidColorBrush x:Key="DangerActiveBrush"   Color="#22DC2626"/>
  </ResourceDictionary>

  <!-- Dark palette -->
  <ResourceDictionary x:Key="Theme.Dark">
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#FF0F0F10"/>
    <SolidColorBrush x:Key="CardBrush"           Color="#FF171718"/>
    <SolidColorBrush x:Key="CardHoverBrush"      Color="#FF202022"/>
    <SolidColorBrush x:Key="CardPressedBrush"    Color="#FF2A2A2D"/>
    <SolidColorBrush x:Key="BorderBrushLight"    Color="#FF2C2C2F"/>
    <SolidColorBrush x:Key="BorderBrushHover"    Color="#FF3C3C3F"/>
    <SolidColorBrush x:Key="TextBrush"           Color="#FFEAEAEA"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="#FF9A9A9A"/>
    <SolidColorBrush x:Key="AccentLightBrush"    Color="#FFBEBEBE"/>
    <SolidColorBrush x:Key="NavBrush"            Color="#FF09090A"/>
    <SolidColorBrush x:Key="HighlightBrush"      Color="#FF2DD4BF"/>
    <SolidColorBrush x:Key="HighlightLightBrush" Color="#FF5EEAD4"/>
    <SolidColorBrush x:Key="DangerBrush"         Color="#FFEF4444"/>
    <SolidColorBrush x:Key="DangerHoverBrush"    Color="#FFFF6B6B"/>
    <SolidColorBrush x:Key="DangerActiveBrush"   Color="#22EF4444"/>
  </ResourceDictionary>

</ResourceDictionary>
