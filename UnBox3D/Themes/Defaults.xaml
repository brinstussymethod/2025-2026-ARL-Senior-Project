<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Design-time and startup fallbacks (Light).
       ThemeManager appends the active theme LAST at runtime and overrides these. -->
  <SolidColorBrush x:Key="SurfaceBrush"       Color="#FFFFFFFF"/>
  <SolidColorBrush x:Key="CardBrush"          Color="#FFF5F5F5"/>
  <SolidColorBrush x:Key="CardHoverBrush"     Color="#FFEFEFEF"/>
  <SolidColorBrush x:Key="CardPressedBrush"   Color="#FFE6E6E6"/>
  <SolidColorBrush x:Key="BorderBrushLight"   Color="#FFDDDDDD"/>
  <SolidColorBrush x:Key="BorderBrushHover"   Color="#FFBFBFBF"/>
  <SolidColorBrush x:Key="TextBrush"          Color="#FF1A1A1A"/>
  <SolidColorBrush x:Key="AccentBrush"        Color="#FF666666"/>
  <SolidColorBrush x:Key="AccentLightBrush"   Color="#FF8C8C8C"/>
  <!-- New keys (also defined in both Theme.Light and Theme.Dark in Colors.xaml) -->
  <SolidColorBrush x:Key="NavBrush"           Color="#FFF0F0F0"/>
  <SolidColorBrush x:Key="HighlightBrush"     Color="#FF0D9488"/>
  <SolidColorBrush x:Key="HighlightLightBrush" Color="#FF14B8A6"/>
  <SolidColorBrush x:Key="DangerBrush"        Color="#FFDC2626"/>
  <SolidColorBrush x:Key="DangerHoverBrush"   Color="#FFEF4444"/>
  <SolidColorBrush x:Key="DangerActiveBrush"  Color="#33DC2626"/>
</ResourceDictionary>
