<Window x:Class="UnBox3D.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Width="440" Height="240"
        ShowInTaskbar="False"
        Background="Transparent">

    <Border Background="{DynamicResource NavBrush}"
            BorderBrush="{DynamicResource BorderBrushHover}"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <StackPanel x:Name="SplashContent"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Opacity="0">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="SplashContentSlide" Y="14"/>
                </StackPanel.RenderTransform>

                <Image Source="pack://application:,,,/Assets/Icons/logo.ico"
                       Width="48" Height="48"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center"/>

                <TextBlock Text="UnBox3D"
                           FontFamily="Segoe UI" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>

                <TextBlock Text="3D mesh simplification  ·  laser-cut pattern generation"
                           FontFamily="Segoe UI" FontSize="11.5"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>

                <!-- Animated loading bar -->
                <Grid Width="160" Height="3" Margin="0,18,0,0"
                      HorizontalAlignment="Center" ClipToBounds="True">
                    <Border Background="{DynamicResource BorderBrushLight}" CornerRadius="1.5"/>
                    <Border x:Name="LoadBar"
                            HorizontalAlignment="Left" Width="60" CornerRadius="1.5"
                            Background="{DynamicResource HighlightBrush}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="LoadBarSlide" X="-60"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>

                <TextBlock Text="Loading..."
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,9,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
