<Window x:Class="UnBox3D.Views.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UnBox3D — Main Menu"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="600" MinHeight="480"
        Height="620" Width="900"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Icon="pack://application:,,,/Assets/Icons/logo.ico">

    <DockPanel Background="{DynamicResource SurfaceBrush}">

        <!-- ═══ Top bar ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource NavBrush}"
                BorderBrush="{DynamicResource BorderBrushLight}"
                BorderThickness="0,0,0,1"
                Padding="24,13">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/Icons/logo.ico"
                           Width="22" Height="22" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center"/>
                    <TextBlock Text="UnBox3D"
                               FontFamily="Segoe UI" FontSize="17" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrushLight}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v1.0"
                                   FontFamily="Cascadia Code, Consolas" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Dark mode" FontSize="12"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,9,0"/>
                    <ToggleButton x:Name="DarkModeToggle"
                                  Style="{StaticResource SwitchStyle}"
                                  Focusable="False" IsTabStop="False"
                                  ToolTip="Toggle dark / light mode"
                                  Click="ToggleTheme_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Status bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="Press Enter to start  ·  Alt+O to open  ·  Esc to exit"
                           FontFamily="Segoe UI" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Content — fills ALL remaining space ═══ -->
        <Grid>
            <!-- Hero section top -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Heading -->
            <StackPanel Grid.Row="0" Margin="48,32,48,0"
                        HorizontalAlignment="Center">
                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <!-- Title: fade in + slide up -->
                                <DoubleAnimation Storyboard.TargetName="HeroTitle"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.55"
                                                 BeginTime="0:0:0.05">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HeroTitleSlide"
                                                 Storyboard.TargetProperty="Y"
                                                 From="18" To="0" Duration="0:0:0.55"
                                                 BeginTime="0:0:0.05">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <!-- Subtitle: fade in -->
                                <DoubleAnimation Storyboard.TargetName="HeroSubtitle"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.5"
                                                 BeginTime="0:0:0.3">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <!-- Line: materialise from centre outward -->
                                <DoubleAnimation Storyboard.TargetName="HeroLineScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 From="0" To="1" Duration="0:0:0.65"
                                                 BeginTime="0:0:0.7">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HeroLine"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.15"
                                                 BeginTime="0:0:0.7"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>

                <TextBlock x:Name="HeroTitle"
                           Text="Welcome back."
                           FontFamily="Segoe UI" FontSize="36" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           TextAlignment="Center" TextWrapping="Wrap"
                           Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="HeroTitleSlide"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="HeroSubtitle"
                           Text="3D mesh simplification · laser-cut pattern generation"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="{DynamicResource AccentBrush}"
                           TextAlignment="Center" TextWrapping="Wrap"
                           Margin="0,6,0,0" Opacity="0"/>

                <!-- Line stretches to full text width, ScaleX animates from centre outward -->
                <Border x:Name="HeroLine"
                        Height="2" HorizontalAlignment="Stretch"
                        Background="{DynamicResource HighlightBrush}"
                        CornerRadius="1" Margin="0,16,0,0" Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="HeroLineScale" ScaleX="0"/>
                    </Border.RenderTransform>
                </Border>
            </StackPanel>

            <!-- Spacer -->
            <Border Grid.Row="1" Height="20"/>

            <!-- Button list — scrollable so Exit is never cut off on short windows -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="48,0,48,32" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Start -->
                <Button Grid.Row="0" x:Name="BtnStart" IsDefault="True"
                        Height="64" Margin="0,0,0,10"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Start_Click">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9"
                                Background="{DynamicResource HighlightBrush}" Margin="0,0,14,0">
                            <TextBlock Text="▶" FontSize="13" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Start new session"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="Open the 3D editor"
                                       FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrushLight}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,3" Margin="0,0,4,0" VerticalAlignment="Center">
                            <TextBlock Text="Enter" FontSize="11" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Open -->
                <Button Grid.Row="1" x:Name="BtnOpen" Height="64" Margin="0,0,0,10"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Open_Click">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9"
                                Background="{DynamicResource CardHoverBrush}"
                                BorderBrush="{DynamicResource BorderBrushHover}"
                                BorderThickness="1" Margin="0,0,14,0">
                            <TextBlock Text="📂" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Open existing..."
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="Load a saved session or OBJ"
                                       FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrushLight}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,3" Margin="0,0,4,0" VerticalAlignment="Center">
                            <TextBlock Text="Alt+O" FontSize="11" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Settings -->
                <Button Grid.Row="2" x:Name="BtnSettings" Height="64" Margin="0,0,0,10"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Settings_Click">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9"
                                Background="{DynamicResource CardHoverBrush}"
                                BorderBrush="{DynamicResource BorderBrushHover}"
                                BorderThickness="1" Margin="0,0,14,0">
                            <TextBlock Text="⚙" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Settings"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="Configure rendering &amp; UI preferences"
                                       FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrushLight}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,3" Margin="0,0,4,0" VerticalAlignment="Center">
                            <TextBlock Text="Alt+S" FontSize="11" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Help -->
                <Button Grid.Row="3" x:Name="BtnHelp" Height="64" Margin="0,0,0,10"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Help_Click">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9"
                                Background="{DynamicResource CardHoverBrush}"
                                BorderBrush="{DynamicResource BorderBrushHover}"
                                BorderThickness="1" Margin="0,0,14,0">
                            <TextBlock Text="?" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Help"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="Keyboard shortcuts &amp; usage guide"
                                       FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrushLight}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,3" Margin="0,0,4,0" VerticalAlignment="Center">
                            <TextBlock Text="Alt+H" FontSize="11" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Divider -->
                <Border Grid.Row="4" Height="1" Background="{DynamicResource BorderBrushLight}" Margin="0,6,0,10"/>

                <!-- Exit -->
                <Button Grid.Row="5" x:Name="BtnExit" Height="64" Margin="0,0,0,0"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Exit_Click">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9"
                                Background="{DynamicResource DangerActiveBrush}"
                                Margin="0,0,14,0">
                            <TextBlock Text="✕" FontSize="13"
                                       Foreground="{DynamicResource DangerBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Exit"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="2"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrushLight}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,3" Margin="0,0,4,0" VerticalAlignment="Center">
                            <TextBlock Text="Esc" FontSize="11" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </Grid>
                </Button>

            </Grid>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>