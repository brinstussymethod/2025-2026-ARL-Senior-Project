<Window x:Class="UnBox3D.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UnBox3D — Settings"
        Height="620" Width="780"
        MinHeight="500" MinWidth="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <DockPanel Background="{DynamicResource SurfaceBrush}">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource NavBrush}"
                BorderBrush="{DynamicResource BorderBrushLight}"
                BorderThickness="0,0,0,1"
                Padding="16,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="← Back"
                        Click="BackButton_Click"
                        Padding="12,5"
                        FontSize="12"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="3" CornerRadius="1.5"
                            Background="{DynamicResource HighlightBrush}"
                            Margin="0,0,9,0"/>
                    <TextBlock Text="Settings"
                               FontFamily="Segoe UI"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>

                <!-- ═══ GENERAL ═══ -->
                <TextBlock Text="GENERAL" Style="{StaticResource SectionLabelStyle}"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Splash Screen Duration (s)"
                                   VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 x:Name="splash_screen_opt"
                                 Text="5"
                                 Margin="0,0,0,10"
                                 TextChanged="TextBox_InputChanged"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Export Directory"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 x:Name="export_path_opt"
                                 Text="C:\\ProgramData\\UnBox3D\\Export"
                                 TextChanged="TextBox_PathChanged"/>
                    </Grid>
                </Border>

                <!-- ═══ ASSIMP ═══ -->
                <TextBlock Text="ASSIMP IMPORT" Style="{StaticResource SectionLabelStyle}" Margin="0,6,0,7"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Triangulation"                 VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="0" Grid.Column="1" x:Name="triangulation_opt"           IsChecked="True"  VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Join Identical Vertices"       VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="1" Grid.Column="1" x:Name="join_identical_vertices_opt" IsChecked="True"  VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Component Removal"             VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="2" Grid.Column="1" x:Name="component_removal_opt"       IsChecked="False" VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Split Large Meshes"            VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="split_large_meshes_opt"      IsChecked="True"  VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Optimize Meshes"               VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="4" Grid.Column="1" x:Name="optimize_meshes_opt"         IsChecked="True"  VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Find Degenerates"              VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="5" Grid.Column="1" x:Name="find_degens_opt"             IsChecked="True"  VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Find Invalid Data"             VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="6" Grid.Column="1" x:Name="find_invalid_data_opt"       IsChecked="True"  VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Ignore Invalid Data"           VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="7" Grid.Column="1" x:Name="ignore_invalid_data_opt"     IsChecked="False" VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                    </Grid>
                </Border>

                <!-- ═══ RENDERING ═══ -->
                <TextBlock Text="RENDERING" Style="{StaticResource SectionLabelStyle}" Margin="0,6,0,7"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Background Color"  VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="background_color_opt"     Text="lightgrey"  TextChanged="TextBox_InputChanged"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mesh Color"                 VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="mesh_color_opt"            Text="red"        TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Mesh Highlight Color"        VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="mesh_highlight_color_opt"  Text="cyan"       TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Render Mode"                 VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="render_mode_opt"           Text="wireframe"  TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Shading Model"               VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="shading_model_opt"         Text="smooth"     TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Enable Lighting"             VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <CheckBox  Grid.Row="5" Grid.Column="1" x:Name="enable_lighting_opt"       IsChecked="True"  VerticalAlignment="Center" Click="CheckBox_Toggled" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Enable Shadows"              VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <CheckBox  Grid.Row="6" Grid.Column="1" x:Name="enable_shadows_opt"        IsChecked="False" VerticalAlignment="Center" Click="CheckBox_Toggled" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- ═══ UI ═══ -->
                <TextBlock Text="USER INTERFACE" Style="{StaticResource SectionLabelStyle}" Margin="0,6,0,7"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tool Strip Position"   VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="tool_strip_position_opt"  Text="top"  TextChanged="TextBox_InputChanged"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Camera Yaw Sensitivity"     VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="camera_yaw_factor_opt"    Text="0.2"  TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Camera Pitch Sensitivity"   VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="camera_pitch_factor_opt"  Text="0.2"  TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Camera Pan Sensitivity"     VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="camera_pan_factor_opt"    Text="10.0" TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Mesh Rotate Sensitivity"    VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="mesh_rotate_factor_opt"   Text="0.2"  TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Mesh Move Sensitivity"      VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="5" Grid.Column="1" x:Name="mesh_move_factor_opt"     Text="0.2"  TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Zoom Sensitivity"           VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="6" Grid.Column="1" x:Name="zoom_factor_opt"          Text="1.0"  TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- ═══ UNITS ═══ -->
                <TextBlock Text="MEASUREMENT UNITS" Style="{StaticResource SectionLabelStyle}" Margin="0,6,0,7"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Default Unit"          VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="default_unit_opt"    Text="Feet"  TextChanged="TextBox_InputChanged"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Use Metric System"     VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <CheckBox  Grid.Row="1" Grid.Column="1" x:Name="enable_metric_system_opt" IsChecked="False" VerticalAlignment="Center" Click="CheckBox_Toggled" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- ═══ WINDOW ═══ -->
                <TextBlock Text="WINDOW SIZING" Style="{StaticResource SectionLabelStyle}" Margin="0,6,0,7"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Enable Fullscreen"     VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="0" Grid.Column="1" x:Name="fullscreen_opt"      IsChecked="False" VerticalAlignment="Center" Click="CheckBox_Toggled"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Default Height"        VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="default_window_height_opt" Text="720" TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Default Width"         VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="default_window_width_opt"  Text="1280" TextChanged="TextBox_InputChanged" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- bottom padding -->
                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
