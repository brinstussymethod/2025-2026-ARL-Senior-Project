<Window x:Class="UnBox3D.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help — UnBox3D"
        Height="640" Width="800"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Background="{DynamicResource SurfaceBrush}">

    <DockPanel>

        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource NavBrush}"
                BorderBrush="{DynamicResource BorderBrushLight}"
                BorderThickness="0,0,0,1"
                Padding="16,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="3" CornerRadius="1.5"
                            Background="{DynamicResource HighlightBrush}"
                            Margin="0,0,9,0"/>
                    <TextBlock Text="Help"
                               FontFamily="Segoe UI"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom action bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource NavBrush}"
                BorderBrush="{DynamicResource BorderBrushLight}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close"
                        Padding="14,7"
                        IsCancel="True"
                        Click="Close_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,18">
            <StackPanel>

                <!-- About blurb -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="UnBox3D"
                                   FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,6"/>
                        <Border Height="2" Width="32" HorizontalAlignment="Left"
                                Background="{DynamicResource HighlightBrush}"
                                CornerRadius="1" Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="Converts complex 3D geometries into simplified 2D unfolded representations for precise laser-cutting. Explore and manipulate 3D objects using mouse and keyboard controls, then export ready-to-use patterns for physical assembly."/>
                    </StackPanel>
                </Border>

                <!-- Keyboard shortcuts -->
                <TextBlock Text="KEYBOARD SHORTCUTS"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="0,6,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <UniformGrid Rows="1" Columns="2">

                        <!-- Left column -->
                        <StackPanel Margin="0,0,16,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="Enter" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Start session"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="Alt+O" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Open project file"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="Alt+S" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Open settings"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="Esc" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Close dialog / exit view"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="Alt+F4" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Close application"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="W / S" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Move forward / backward"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="A / D" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Move camera left / right"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="Space" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Move camera up"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="L-Shift" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Move camera down"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource KbdBadgeStyle}">
                                    <TextBlock Text="Q / E" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Roll camera left / right"
                                           FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <!-- Mouse controls -->
                <TextBlock Text="MOUSE CONTROLS"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="0,6,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource KbdBadgeStyle}" MinWidth="100">
                                <TextBlock Text="Left Button" FontFamily="Cascadia Code, Consolas"
                                           FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Select objects in hierarchy"
                                       FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource KbdBadgeStyle}" MinWidth="100">
                                <TextBlock Text="Right Button" FontFamily="Cascadia Code, Consolas"
                                           FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Hold + drag — rotate camera"
                                       FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource KbdBadgeStyle}" MinWidth="100">
                                <TextBlock Text="Scroll Wheel" FontFamily="Cascadia Code, Consolas"
                                           FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Zoom in / out"
                                       FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource KbdBadgeStyle}" MinWidth="100">
                                <TextBlock Text="Middle Button" FontFamily="Cascadia Code, Consolas"
                                           FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Hold + drag — pan camera"
                                       FontSize="12.5" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Tip -->
                <Border CornerRadius="8"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource HighlightBrush}"
                        BorderThickness="1"
                        Padding="14,10"
                        Margin="0,4,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💡" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Top"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="Tip: Hold the scroll wheel to pan the camera while using W / A / S / D / Space / Shift to move — this lets you view objects from any angle without losing your position."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
