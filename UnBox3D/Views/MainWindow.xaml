<Window x:Class="UnBox3D.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:UnBox3D.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="UnBox3D"
        Height="700" Width="1100"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Icon="pack://application:,,,/Assets/Icons/logo.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Outer Grid so we can layer the notification Popup above the DockPanel -->
    <Grid>
    <DockPanel Background="{DynamicResource SurfaceBrush}">

        <!-- ═══ Menu Bar ═══ -->
        <Border DockPanel.Dock="Top"
        Background="{DynamicResource NavBrush}"
        BorderBrush="{DynamicResource BorderBrushLight}"
        BorderThickness="0,0,0,1">
        <Menu Background="Transparent" BorderThickness="0" Padding="6,2">
        <MenuItem Header="File" FontWeight="Medium">
        <MenuItem Header="← Back to Main Menu" Click="BackToMainMenu_Click"
        FontWeight="SemiBold" Style="{StaticResource SubMenuItemStyle}"/>
        <Separator/>
        <MenuItem Header="Import OBJ..."          Click="ImportModel_Click"          Style="{StaticResource SubMenuItemStyle}"/>
        <MenuItem Header="Export Scene as OBJ..." Click="ExportModel_Click"          Style="{StaticResource SubMenuItemStyle}"/>
        <Separator/>
        <MenuItem Header="Exit"                   Click="Exit_Click"                 Style="{StaticResource SubMenuItemStyle}"/>
        </MenuItem>
        <MenuItem Header="Edit">
        <MenuItem Header="Undo" Command="{Binding UndoActionCommand}" InputGestureText="Ctrl+Z" Style="{StaticResource SubMenuItemStyle}"/>
        <MenuItem Header="Redo" Command="{Binding RedoActionCommand}" InputGestureText="Ctrl+Y" Style="{StaticResource SubMenuItemStyle}"/>
        </MenuItem>
        <MenuItem Header="View">
        <MenuItem Header="Reset View"       Command="{Binding ResetViewCommand}"           Style="{StaticResource SubMenuItemStyle}"/>
        <MenuItem Header="Toggle Hierarchy" Command="{Binding ToggleHierarchyCommand}"     Style="{StaticResource SubMenuItemStyle}"/>
        </MenuItem>
        <MenuItem Header="Tools">
        <MenuItem Header="Replace Scene with Bounding Boxes" Command="{Binding ReplaceSceneWithBoundingBoxesCommand}" Style="{StaticResource SubMenuItemStyle}"/>
        <Separator/>
        <MenuItem Header="Simplify All (QEC)" Command="{Binding SimplifyAllQECCommand}" Style="{StaticResource SubMenuItemStyle}"/>
        <MenuItem Header="Simplify All (FQD)" Command="{Binding SimplifyAllFQDCommand}" Style="{StaticResource SubMenuItemStyle}"/>
        <MenuItem Header="Simplify All (VC)"  Command="{Binding SimplifyAllVCCommand}"  Style="{StaticResource SubMenuItemStyle}"/>
        </MenuItem>
        <MenuItem Header="Settings" Click="Settings_Click"/>
        <MenuItem Header="Help">
        <MenuItem Header="Controls &amp; Shortcuts" Click="Help_Click" Style="{StaticResource SubMenuItemStyle}"/>
        <MenuItem Header="About" Click="About_Click" Style="{StaticResource SubMenuItemStyle}"/>
        </MenuItem>
        </Menu>
        </Border>

        <!-- ═══ Toolbar ═══ -->
        <Border x:Name="ToolbarBorder" DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushLight}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <StackPanel Orientation="Horizontal">

                <!-- Undo -->
                <Button ToolTip="Undo  (Ctrl+Z)"
                        Command="{Binding UndoActionCommand}"
                        Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x21A9;" FontSize="14" Margin="0,0,5,0"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Undo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Redo -->
                <Button ToolTip="Redo  (Ctrl+Y)"
                        Command="{Binding RedoActionCommand}"
                        Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x21AA;" FontSize="14" Margin="0,0,5,0"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Redo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Divider -->
                <Border Width="1" Height="22" Background="{DynamicResource BorderBrushLight}"
                        Margin="6,0" VerticalAlignment="Center"/>

                <!-- Select -->
                <Button ToolTip="Select — left-click to pick a mesh"
                        Command="{Binding SetSelectModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveMode}" Value="Select">
                                    <Setter Property="Background"  Value="{DynamicResource CardBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource HighlightBrush}"/>
                                    <Setter Property="FontWeight"  Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊙" Margin="0,0,5,0" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource HighlightBrush}"/>
                        <TextBlock Text="Select" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Move -->
                <Button ToolTip="Move — drag a mesh to reposition it"
                        Command="{Binding SetMoveModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveMode}" Value="Move">
                                    <Setter Property="Background"  Value="{DynamicResource CardBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource HighlightBrush}"/>
                                    <Setter Property="FontWeight"  Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2725;" FontSize="13" Margin="0,0,5,0"
                                   Foreground="{DynamicResource HighlightBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Move" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Rotate -->
                <Button ToolTip="Rotate — drag left/right to spin a mesh"
                        Command="{Binding SetRotateModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveMode}" Value="Rotate">
                                    <Setter Property="Background"  Value="{DynamicResource CardBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource HighlightBrush}"/>
                                    <Setter Property="FontWeight"  Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x21BA;" FontSize="14" Margin="0,0,5,0"
                                   Foreground="{DynamicResource HighlightBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Rotate" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Gimbal -->
                <Button ToolTip="Gimbal — click mesh to select, drag rings to rotate on axis, drag body to move"
                        Command="{Binding SetGimbalModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveMode}" Value="Gimbal">
                                    <Setter Property="Background"  Value="{DynamicResource CardBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource HighlightBrush}"/>
                                    <Setter Property="FontWeight"  Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x29BF;" FontSize="13" Margin="0,0,5,0"
                                   Foreground="{DynamicResource HighlightBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Gimbal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Ruler -->
                <Button ToolTip="Ruler — click ground to place, drag arrow to resize, click label to define scale"
                        Command="{Binding SetRulerModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveMode}" Value="Ruler">
                                    <Setter Property="Background"  Value="{DynamicResource CardBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="FontWeight"  Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x22A2;" FontSize="14" Margin="0,0,5,0"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Ruler" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Delete -->
                <Button ToolTip="Delete — click a mesh to remove it"
                        Command="{Binding SetDeleteModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveMode}" Value="Delete">
                                    <Setter Property="Background"  Value="{DynamicResource DangerActiveBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="FontWeight"  Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2715;" FontSize="13" Margin="0,0,5,0"
                                   Foreground="{DynamicResource DangerBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Delete" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Divider -->
                <Border Width="1" Height="22" Background="{DynamicResource BorderBrushLight}"
                        Margin="6,0" VerticalAlignment="Center"/>

                <!-- Hierarchy toggle -->
                <Button ToolTip="Toggle mesh hierarchy  (View → Toggle Hierarchy)"
                        Command="{Binding ToggleHierarchyCommand}"
                        Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2630;" FontSize="13" Margin="0,0,5,0"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Hierarchy" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Divider -->
                <Border Width="1" Height="22" Background="{DynamicResource BorderBrushLight}"
                        Margin="6,0" VerticalAlignment="Center"/>

                <!-- Active mode pill indicator -->
                <Border CornerRadius="5"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrushLight}"
                        BorderThickness="1"
                        Padding="10,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Mode: "
                                   FontSize="12"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ActiveMode, Mode=OneWay}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource HighlightBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ Status bar ═══ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource NavBrush}"
                BorderBrush="{DynamicResource BorderBrushLight}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Thin progress strip (slides when IsBusy) -->
                <ProgressBar Grid.Row="0"
                             Style="{StaticResource StatusBarProgressStyle}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                <!-- Content row -->
                <Grid Grid.Row="1" Margin="12,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: mesh count + status message -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◆ " FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Meshes.Count, StringFormat='{}{0} mesh(es) in scene'}"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" · " FontSize="11.5"
                                   Foreground="{DynamicResource BorderBrushHover}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource HighlightBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Right: toast + mode indicator -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="ToastBorder"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource HighlightBrush}"
                                BorderThickness="1" CornerRadius="5"
                                Padding="10,3" Margin="0,0,10,0"
                                Opacity="0">
                            <TextBlock x:Name="ToastText"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource HighlightBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrushLight}"
                                BorderThickness="1" CornerRadius="5"
                                Padding="10,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Mode: " FontSize="11.5"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ActiveMode}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource HighlightBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ Main content ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HierarchyColumn" Width="260" MinWidth="0" MaxWidth="420"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="240" MinWidth="160" MaxWidth="360"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel: Mesh hierarchy ── -->
            <Border x:Name="HierarchyPanel"
                    Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrushLight}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Panel header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource NavBrush}"
                            BorderBrush="{DynamicResource BorderBrushLight}"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="1.5"
                                    Background="{DynamicResource HighlightBrush}"
                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Meshes"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TreeView x:Name="MeshesTreeView"
                              Grid.Row="1"
                              Padding="6,6"
                              ItemsSource="{Binding Meshes}"
                              SelectedItemChanged="TreeView_SelectedItemChanged"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem"
                                   BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Mesh name + vertex count -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <!-- Shape icon badge -->
                                        <Border Width="24" Height="24" CornerRadius="6"
                                                Background="{Binding ShapeBrush}"
                                                Margin="0,0,8,0" VerticalAlignment="Center"
                                                Opacity="0.22"/>
                                        <TextBlock Text="{Binding ShapeIcon}"
                                                   FontSize="12"
                                                   Foreground="{Binding ShapeBrush}"
                                                   Margin="-30,0,6,0"
                                                   Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource CardBrush}"
                                                BorderBrush="{DynamicResource BorderBrushLight}"
                                                BorderThickness="1" CornerRadius="4"
                                                Padding="5,1" Margin="6,0,0,0"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding VertexCount}"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="10.5"
                                                           Foreground="{DynamicResource HighlightBrush}"/>
                                                <TextBlock Text=" v" FontSize="10.5"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <!-- Action buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <Button Content="Export"
                                                FontSize="11" Padding="8,3"
                                                Command="{Binding DataContext.ExportMeshCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                CommandParameter="{Binding SourceMesh}"/>
                                        <Button Content="Delete"
                                                FontSize="11" Padding="8,3"
                                                Margin="5,0,0,0"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Command="{Binding DataContext.DeleteMeshCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                CommandParameter="{Binding SourceMesh}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter x:Name="HierarchySplitter"
                          Grid.Column="1"
                          Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrushLight}"
                          ShowsPreview="True" Cursor="SizeWE"/>

            <!-- ── Viewport ── -->
            <WindowsFormsHost Grid.Column="2" Name="openGLHost"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3"
                          Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrushLight}"
                          ShowsPreview="True" Cursor="SizeWE"/>

            <!-- ── Right panel: Tools ── -->
            <Border x:Name="ToolsPanel" Grid.Column="4"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrushLight}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Panel header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource NavBrush}"
                            BorderBrush="{DynamicResource BorderBrushLight}"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="1.5"
                                    Background="{DynamicResource AccentBrush}"
                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Tools"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="12,10,12,10">
                        <StackPanel>

                            <!-- Small Mesh Threshold -->
                            <TextBlock Text="SMALL MESH THRESHOLD"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <Slider x:Name="MeshThreshold"
                                    Minimum="0" Maximum="100"
                                    Value="{Binding SmallMeshThreshold, Mode=TwoWay}"
                                    ValueChanged="MeshThreshold_ValueChanged"
                                    Margin="0,0,0,14"/>

                            <!-- Page Size -->
                            <TextBlock Text="UNFOLD PAGE SIZE"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <Border Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="W"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBox Grid.Column="1"
                                             Name="PageWidthTextBox"
                                             Text="{Binding PageWidth, UpdateSourceTrigger=PropertyChanged}"
                                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                                             PreviewKeyDown="NumericTextBox_PreviewKeyDown"
                                             TextChanged="NumericTextBox_TextChanged"
                                             LostFocus="NumericTextBox_LostFocus"/>
                                    <TextBlock Grid.Column="2" Text="H"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="10,0,7,0"/>
                                    <TextBox Grid.Column="3"
                                             Name="PageHeightTextBox"
                                             Text="{Binding PageHeight, UpdateSourceTrigger=PropertyChanged}"
                                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                                             PreviewKeyDown="NumericTextBox_PreviewKeyDown"
                                             TextChanged="NumericTextBox_TextChanged"
                                             LostFocus="NumericTextBox_LostFocus"/>
                                </Grid>
                            </Border>
                            <Button Content="Export Unfolded (SVG/PDF)…"
                                    Command="{Binding ExportUnfoldModelCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,16"/>

                            <!-- Replace -->
                            <TextBlock Text="REPLACE MESH"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <StackPanel Margin="0,0,0,16">
                                <Button HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        Command="{Binding ReplaceWithCylinderClickCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x25D4;" FontSize="13" Margin="0,0,8,0"
                                                   Foreground="{DynamicResource HighlightBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Cylinder" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        Command="{Binding ReplaceWithCubeClickCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x25A1;" FontSize="13" Margin="0,0,8,0"
                                                   Foreground="{DynamicResource HighlightBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Cube / Prism" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button HorizontalAlignment="Stretch"
                                        Command="{Binding ReplaceWithWedgeClickCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x25B7;" FontSize="13" Margin="0,0,8,0"
                                                   Foreground="{DynamicResource HighlightBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Wedge" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Scene -->
                            <TextBlock Text="SCENE" Style="{StaticResource SectionLabelStyle}"/>
                            <Button Content="Clear Scene"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding ClearSceneCommand}"
                                    Margin="0,0,0,16"/>

                            <!-- Import / Export -->
                            <TextBlock Text="IMPORT / EXPORT"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <Button Content="Import OBJ…"
                                    HorizontalAlignment="Stretch"
                                    Click="ImportModel_Click"
                                    Margin="0,0,0,6"/>
                            <Button Content="Export Scene as OBJ…"
                                    HorizontalAlignment="Stretch"
                                    Click="ExportModel_Click"
                                    Margin="0,0,0,16"/>

                            <!-- App -->
                            <TextBlock Text="APPLICATION"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <Button Content="Settings"
                                    HorizontalAlignment="Stretch"
                                    Click="Settings_Click"
                                    Margin="0,0,0,6"/>
                            <Button Content="Exit"
                                    HorizontalAlignment="Stretch"
                                    Click="Exit_Click"
                                    Style="{StaticResource DangerButtonStyle}"/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>

    <!-- ── Notification Popup — its own HWND so it renders above WindowsFormsHost ── -->
    <Popup x:Name="NotifyPopup"
           AllowsTransparency="True"
           StaysOpen="True"
           IsOpen="False"
           PopupAnimation="None">
        <Border x:Name="NotifyBanner"
                HorizontalAlignment="Center"
                Opacity="0"
                CornerRadius="8"
                BorderThickness="1"
                Padding="18,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5" Color="#000000"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="NotifyIcon"
                           FontSize="16" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBlock x:Name="NotifyText"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="380"/>
            </StackPanel>
        </Border>
    </Popup>

    </Grid>
</Window>
