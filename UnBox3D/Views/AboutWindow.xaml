<Window x:Class="UnBox3D.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About — UnBox3D"
        Height="420" Width="500"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Background="{DynamicResource SurfaceBrush}"
        Icon="pack://application:,,,/Assets/Icons/logo.ico">

    <DockPanel>

        <!-- Top accent strip -->
        <Border DockPanel.Dock="Top" Height="3"
                Background="{DynamicResource HighlightBrush}"/>

        <!-- Bottom action bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource NavBrush}"
                BorderBrush="{DynamicResource BorderBrushLight}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Button Content="OK" Width="88" HorizontalAlignment="Right"
                    IsDefault="True" IsCancel="True"
                    Click="OK_Click"/>
        </Border>

        <!-- Body -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,24">

            <!-- Logo + name row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Image Source="pack://application:,,,/Assets/Icons/logo.ico"
                       Width="48" Height="48"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="UnBox3D"
                               FontFamily="Segoe UI" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrushLight}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="7,2">
                            <TextBlock Text="v1.0"
                                       FontFamily="Cascadia Code, Consolas" FontSize="11"
                                       Foreground="{DynamicResource HighlightBrush}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Teal rule -->
            <Border Height="1" Background="{DynamicResource BorderBrushLight}" Margin="0,0,0,16"/>

            <!-- Description -->
            <TextBlock TextWrapping="Wrap" FontSize="13"
                       Foreground="{DynamicResource AccentBrush}"
                       LineHeight="20">
                A 3D mesh simplification and laser-cut pattern generation tool.
                Import OBJ models, simplify geometry, replace meshes with primitive
                shapes, and export unfolded 2D patterns as SVG or PDF.
            </TextBlock>

            <TextBlock Margin="0,14,0,0" FontSize="12"
                       Foreground="{DynamicResource AccentBrush}">
                <Run Text="Built with " Foreground="{DynamicResource AccentBrush}"/>
                <Run Text=".NET 8 · WPF · OpenTK · Assimp"
                     FontFamily="Cascadia Code, Consolas" FontSize="11"
                     Foreground="{DynamicResource TextBrush}"/>
            </TextBlock>
        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
